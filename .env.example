# Server
HOST=0.0.0.0
PORT=8000

# Device settings
DEVICE=cpu
FAISS_USE_GPU=false

# Paths
DATA_DIR=data

# CLAP model identifier (HuggingFace)
CLAP_MODEL_NAME=laion/larger_clap_music_and_speech

# Anomaly detection
ANOMALY_THRESHOLD=0.55
DETECTION_INTERVAL_SEC=300

# LLM (local Qwen2.5-7B-Instruct, requires GPU)
LLM_ENABLED=false
LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
LLM_MAX_NEW_TOKENS=512

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Debug mode
DEBUG=false

# Slack notification
SLACK_WEBHOOK_URL=

# Frontend
VITE_API_URL=http://localhost:8000
VITE_POLL_INTERVAL=5000

# Demo mode
DEMO_ENABLED=true
