# Server
HOST=0.0.0.0
PORT=8000

# Device settings (GPU server)
DEVICE=cuda
FAISS_USE_GPU=true

# Paths (use absolute path on server)
# DATA_DIR=/path/to/project/data

# CLAP model
CLAP_MODEL_NAME=laion/larger_clap_music_and_speech

# Anomaly detection
ANOMALY_THRESHOLD=0.55
# GPU: 3秒間隔でリアルタイム検知 (CPUでは間に合わないのでGPUならでは)
DETECTION_INTERVAL_SEC=3

# LLM (local Qwen2.5-7B-Instruct on GPU)
LLM_ENABLED=true
LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
LLM_MAX_NEW_TOKENS=512

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Slack notification
SLACK_WEBHOOK_URL=

# Debug
DEBUG=false

# Frontend
# VITE_API_URL=https://your-production-server.example.com
VITE_POLL_INTERVAL=2000

# Demo mode
DEMO_ENABLED=false
